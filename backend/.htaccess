# Configuración de Apache para el backend de BookIt

# CORS se maneja dinámicamente en conexion.php
# Este archivo solo configura seguridad básica

# Desactivar listado de directorios
Options -Indexes

# Prevenir acceso a archivos .htaccess y .sql
<FilesMatch "\.(htaccess|htpasswd|ini|log|sql)$">
    Require all denied
</FilesMatch>

# Habilitar PHP en todos los directorios
<FilesMatch "\.php$">
    SetHandler application/x-httpd-php
</FilesMatch>
